{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillbase.dev/schemas/cli/pipeline-output.schema.json",
  "title": "Skillbase Pipeline JSON Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "mode", "failOnWarnings", "mutating", "stages", "evaluation"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "status": { "type": "integer", "minimum": 0 },
    "mode": { "type": "string", "const": "run" },
    "failOnWarnings": { "type": "boolean" },
    "mutating": { "type": "boolean" },
    "stages": {
      "type": "object",
      "additionalProperties": false,
      "required": ["update", "scan", "apply"],
      "properties": {
        "update": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "lockfile", "lockfileVerified", "sources", "skills", "trust"],
          "properties": {
            "status": { "type": "integer", "minimum": 0 },
            "code": { "type": "string" },
            "reason": { "type": "string" },
            "lockfile": { "type": "string", "minLength": 1 },
            "lockfileVerified": { "type": "boolean" },
            "sources": { "type": "integer", "minimum": 0 },
            "skills": { "type": "integer", "minimum": 0 },
            "trust": {
              "type": "object",
              "additionalProperties": false,
              "required": ["summary"],
              "properties": {
                "summary": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["totalSources", "verifiedSources", "untrustedSources", "requiredSources"],
                  "properties": {
                    "totalSources": { "type": "integer", "minimum": 0 },
                    "verifiedSources": { "type": "integer", "minimum": 0 },
                    "untrustedSources": { "type": "integer", "minimum": 0 },
                    "requiredSources": { "type": "integer", "minimum": 0 }
                  }
                }
              }
            }
          }
        },
        "scan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "summary"],
          "properties": {
            "status": { "type": "integer", "minimum": 0 },
            "skipped": { "type": "boolean" },
            "reason": { "type": "string" },
            "summary": {
              "type": "object",
              "additionalProperties": false,
              "required": ["skills", "lintIssues", "highFindings", "mediumFindings", "suppressedFindings"],
              "properties": {
                "skills": { "type": "integer", "minimum": 0 },
                "lintIssues": { "type": "integer", "minimum": 0 },
                "highFindings": { "type": "integer", "minimum": 0 },
                "mediumFindings": { "type": "integer", "minimum": 0 },
                "suppressedFindings": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "apply": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "dryRun", "operations", "summary"],
          "properties": {
            "status": { "type": "integer", "minimum": 0 },
            "skipped": { "type": "boolean" },
            "reason": { "type": "string" },
            "dryRun": { "type": "boolean" },
            "operations": { "type": "integer", "minimum": 0 },
            "lockfileVerified": { "type": "boolean" },
            "summary": {
              "type": "object",
              "additionalProperties": false,
              "required": ["lintIssues", "highFindings", "mediumFindings", "suppressedFindings"],
              "properties": {
                "lintIssues": { "type": "integer", "minimum": 0 },
                "highFindings": { "type": "integer", "minimum": 0 },
                "mediumFindings": { "type": "integer", "minimum": 0 },
                "suppressedFindings": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "score", "reasons"],
      "properties": {
        "gate": { "type": "string", "enum": ["pass", "warn", "blocked"] },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
