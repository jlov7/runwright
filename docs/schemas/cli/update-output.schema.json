{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillbase.dev/schemas/cli/update-output.schema.json",
  "title": "Skillbase Update JSON Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "lockfileVerified", "sources", "skills", "trust"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "status": { "type": "integer", "minimum": 0 },
    "code": { "type": "string" },
    "reason": { "type": "string" },
    "lockfileVerified": { "type": "boolean" },
    "lockfile": { "type": "string" },
    "sources": { "type": "integer", "minimum": 0 },
    "skills": { "type": "integer", "minimum": 0 },
    "trust": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["totalSources", "verifiedSources", "untrustedSources", "requiredSources"],
          "properties": {
            "totalSources": { "type": "integer", "minimum": 0 },
            "verifiedSources": { "type": "integer", "minimum": 0 },
            "untrustedSources": { "type": "integer", "minimum": 0 },
            "requiredSources": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
