{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillbase.dev/schemas/quality/release-attestation.schema.json",
  "title": "Runwright Release Attestation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "predicateType", "subject", "builder", "run", "signature"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "predicateType": { "type": "string", "minLength": 1 },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sizeBytes", "digest"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "digest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sha256"],
          "properties": {
            "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
          }
        }
      }
    },
    "builder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invocationId", "sourceRef", "workflow"],
      "properties": {
        "invocationId": { "type": "string", "minLength": 1 },
        "sourceRef": { "type": "string", "minLength": 1 },
        "workflow": { "type": "string", "minLength": 1 }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "keyId", "payloadDigest", "value"],
      "properties": {
        "algorithm": { "const": "ed25519" },
        "keyId": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "payloadDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "value": {
          "type": "string",
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}(?:==)?|[A-Za-z0-9+/]{3}=?)?$"
        }
      }
    }
  }
}
