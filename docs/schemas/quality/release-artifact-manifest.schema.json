{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillbase.dev/schemas/quality/release-artifact-manifest.schema.json",
  "title": "Skillbase Release Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "baseDir", "rootHash", "files"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "baseDir": { "type": "string", "minLength": 1 },
    "rootHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sizeBytes", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sizeBytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    }
  }
}
